// =============================================================================
// Quick Mean Reversion v1.0 — 15m BACKTEST STRATEGY
//
// Higher frequency adaptation of the proven 4H Mean Reversion v1.3 logic.
// Catches quick oversold bounces on 15m — resolves within a few candles.
//
// Key differences from 4H version:
//   - Faster RSI (9) instead of 14 — responds quicker on 15m
//   - BB(14, 2.0) tighter than 4H BB(20, 2.0) — more touches
//   - Simplified to 3 confirmations: RSI oversold + volume + EMA trend
//   - No Banker Fund Flow or Choppiness (too noisy on 15m)
//   - LONGS ONLY (same as 4H — shorts underperform on uptrending crypto)
//   - Tighter TP/SL for faster resolution
//
// Target: SOL, ETH on 15m — 2 alert slots
// =============================================================================

//@version=6
strategy("Quick MeanRev v1 — 15m Backtest", overlay=true, max_bars_back=500,
         initial_capital=1000, default_qty_type=strategy.percent_of_equity,
         default_qty_value=15, commission_type=strategy.commission.percent,
         commission_value=0.1, slippage=3)

// =============================================================================
// INPUTS
// =============================================================================

grp_bb = "Bollinger Bands"
bb_len  = input.int(14, "Length", minval=10, maxval=30, group=grp_bb)
bb_mult = input.float(2.0, "Multiplier", minval=1.5, maxval=3.0, step=0.1, group=grp_bb)

grp_rsi = "RSI"
rsi_len = input.int(9, "Length", minval=5, maxval=20, group=grp_rsi)
rsi_os  = input.float(30, "Oversold Level", minval=15, maxval=40, step=1, group=grp_rsi)
rsi_exit = input.float(60, "Exit Level (take profit zone)", minval=50, maxval=80, step=5, group=grp_rsi)

grp_vol = "Volume"
vol_len  = input.int(20, "MA Length", group=grp_vol)
vol_mult = input.float(1.2, "Spike Multiplier", minval=1.0, maxval=2.0, step=0.1, group=grp_vol)

grp_trend = "Trend Filter"
ema_len = input.int(100, "EMA Length (trend)", minval=50, maxval=200, group=grp_trend)
use_ema_filter = input.bool(true, "Require Price > EMA (buy dips in uptrend only)", group=grp_trend)

grp_risk = "Risk Management"
sl_atr_mult  = input.float(1.2, "SL ATR Multiplier", minval=0.5, maxval=3.0, step=0.1, group=grp_risk)
tp_atr_mult  = input.float(2.5, "TP ATR Multiplier", minval=1.0, maxval=5.0, step=0.5, group=grp_risk)
atr_len      = input.int(14, "ATR Length", group=grp_risk)
use_rsi_exit = input.bool(true, "Also exit when RSI reaches exit level", group=grp_risk)

grp_cool = "Cooldown"
cooldown_bars = input.int(4, "Bars Between Signals", minval=1, maxval=20, group=grp_cool)

grp_deep = "Deep Dip Override"
use_deep_dip = input.bool(true, "Enable deep dip override", group=grp_deep)
deep_dip_atr_mult = input.float(1.5, "ATR below lower BB = deep dip", minval=1.0, maxval=3.0, step=0.5, group=grp_deep)

// =============================================================================
// CALCULATIONS
// =============================================================================

// Bollinger Bands
[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_len, bb_mult)

// RSI
rsi_val = ta.rsi(close, rsi_len)

// Volume
vol_ma = ta.sma(volume, vol_len)
vol_spike = volume > vol_ma * vol_mult

// Trend
ema_trend = ta.ema(close, ema_len)
in_uptrend = not use_ema_filter or close > ema_trend

// ATR
atr_val = ta.atr(atr_len)

// Cooldown
var int bars_since = 100
bars_since := bars_since + 1
cooldown_ok = bars_since >= cooldown_bars

// =============================================================================
// ENTRY: LONGS ONLY — buy oversold dips in uptrends
// =============================================================================

// BB gate: price must touch or pierce lower band
bb_touch = close <= bb_lower or low <= bb_lower

// Standard entry: BB touch + RSI oversold + volume spike + uptrend
confirm_rsi = rsi_val < rsi_os
standard_entry = bb_touch and confirm_rsi and vol_spike and in_uptrend and cooldown_ok

// Deep dip override: extreme drop below BB, only need RSI confirmation
// Catches capitulation wicks that normal logic might miss
deep_dip = use_deep_dip and low < (bb_lower - deep_dip_atr_mult * atr_val)
deep_entry = deep_dip and confirm_rsi and cooldown_ok

// Combined
long_signal = (standard_entry or deep_entry) and barstate.isconfirmed

if long_signal
    bars_since := 0

// =============================================================================
// EXECUTION
// =============================================================================

if long_signal
    sl = close - sl_atr_mult * atr_val
    tp = close + tp_atr_mult * atr_val
    strategy.entry("QMR Long", strategy.long)
    strategy.exit("QMR Exit", "QMR Long", stop=sl, limit=tp)

// RSI exit — take profit when momentum is back
if use_rsi_exit and strategy.position_size > 0 and rsi_val > rsi_exit
    strategy.close("QMR Long", comment="RSI Exit")

// =============================================================================
// PLOTS
// =============================================================================

p_upper = plot(bb_upper, "BB Upper", color=color.new(color.blue, 60))
p_lower = plot(bb_lower, "BB Lower", color=color.new(color.blue, 60))
plot(bb_mid, "BB Mid", color=color.new(color.orange, 40), linewidth=1)
fill(p_upper, p_lower, color=color.new(color.blue, 92))
plot(ema_trend, "EMA Trend", color=color.new(color.white, 40), linewidth=2)

plotshape(standard_entry, "Buy", shape.triangleup, location.belowbar, color.lime, size=size.small)
plotshape(deep_entry and not standard_entry, "Deep Dip", shape.triangleup, location.belowbar, color.aqua, size=size.small)

bgcolor(close <= bb_lower ? color.new(color.green, 92) : na)
bgcolor(deep_dip ? color.new(color.aqua, 88) : na)

// Info table
var table t = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "15m QMR v1", text_color=color.aqua, text_size=size.small)
    table.cell(t, 1, 0, "LONG ONLY", text_color=color.lime, text_size=size.small)
    table.cell(t, 0, 1, "BB Gate", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, bb_touch ? "TOUCH" : "—", text_color=bb_touch ? color.lime : color.gray, text_size=size.small)
    table.cell(t, 0, 2, "RSI(" + str.tostring(rsi_len) + ")", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(math.round(rsi_val, 1)), text_color=confirm_rsi ? color.lime : color.white, text_size=size.small)
    table.cell(t, 0, 3, "Volume", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, vol_spike ? "SPIKE" : "normal", text_color=vol_spike ? color.lime : color.gray, text_size=size.small)
    table.cell(t, 0, 4, "EMA Trend", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, in_uptrend ? "UP" : "DOWN", text_color=in_uptrend ? color.lime : color.red, text_size=size.small)
    table.cell(t, 0, 5, "Cooldown", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, cooldown_ok ? "READY" : str.tostring(cooldown_bars - bars_since) + " bars", text_color=cooldown_ok ? color.lime : color.yellow, text_size=size.small)
