//@version=5
strategy("EMA Momentum v1", overlay=true, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=15, commission_value=0.1)

// === EMA Momentum Strategy ===
// Trend-following with EMA stack + ADX strength + volume confirmation
// Entry: EMA 9 > 21 > 50, ADX trending, volume spike, RSI not overbought
// Exit: ATR-based SL/TP with trailing stop

// --- Inputs ---
ema9   = ta.ema(close, 9)
ema21  = ta.ema(close, 21)
ema50  = ta.ema(close, 50)
sma200 = ta.sma(close, 200)

// ADX
adxLen = 14
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)

// RSI
rsiVal = ta.rsi(close, 14)

// Volume
volMA  = ta.sma(volume, 20)
volSpike = volume > volMA * 1.3

// ATR for stops
atrVal = ta.atr(14)

// --- Conditions ---
emaStackBull = ema9 > ema21 and ema21 > ema50
emaStackBear = ema9 < ema21 and ema21 < ema50
aboveSma200  = close > sma200
adxTrending  = adxVal > 20
rsiNotOB     = rsiVal < 70
rsiNotOS     = rsiVal > 30

// Cooldown
var int lastEntry = 0
cooldownOk = bar_index - lastEntry >= 5

// --- Entry ---
longCond  = emaStackBull and aboveSma200 and adxTrending and volSpike and rsiNotOB and cooldownOk
shortCond = emaStackBear and not aboveSma200 and adxTrending and volSpike and rsiNotOS and cooldownOk

if longCond
    strategy.entry("Long", strategy.long)
    lastEntry := bar_index

if shortCond
    strategy.entry("Short", strategy.short)
    lastEntry := bar_index

// --- Exit ---
slMult = 1.5
tpMult = 3.5
trailAct = 1.5
trailOff = 1.0

if strategy.position_size > 0
    sl = strategy.position_avg_price - slMult * atrVal
    tp = strategy.position_avg_price + tpMult * atrVal
    trailPrice = strategy.position_avg_price + trailAct * atrVal
    strategy.exit("XL", "Long", stop=sl, limit=tp, trail_price=trailPrice, trail_offset=math.round(trailOff * atrVal / syminfo.mintick))

if strategy.position_size < 0
    sl = strategy.position_avg_price + slMult * atrVal
    tp = strategy.position_avg_price - tpMult * atrVal
    trailPrice = strategy.position_avg_price - trailAct * atrVal
    strategy.exit("XS", "Short", stop=sl, limit=tp, trail_price=trailPrice, trail_offset=math.round(trailOff * atrVal / syminfo.mintick))

// Flip exit
if emaStackBear and strategy.position_size > 0
    strategy.close("Long", comment="EMA Flip")
if emaStackBull and strategy.position_size < 0
    strategy.close("Short", comment="EMA Flip")

// --- Plots ---
plot(ema9, "EMA9", color.green)
plot(ema21, "EMA21", color.orange)
plot(ema50, "EMA50", color.red)
plot(sma200, "SMA200", color.gray)
