// =============================================================================
// SOL Confluence Pro v3.5 - BACKTEST STRATEGY
// Optimized for 1H timeframe + small capital ($100 starting)
//
// v3.5 CHANGES — "Better Entries, Not Better Exits" approach:
//   After 5 iterations (v3-v3.4) of exit tuning, PF stayed 0.71-0.84.
//   The problem is entry quality, not exit management. v2 proved
//   confluence >= 5 has real edge (PF 2.336 on Daily). On 1H, we
//   lowered to 4 for more trades — but diluted signal quality below
//   profitability.
//
//   KEY CHANGES:
//   1. Min confluence: 5 (from 4) — proven edge, fewer but better trades
//   2. Position size: 25% (from 10%) — bigger bets on stronger signals
//   3. ADX filter: ADX(14) > 20 required — only trade in trending markets
//   4. TP: 3.5x ATR — reasonable target for quality entries
//   5. Trail activate: 1.5x ATR, offset 1.0x ATR — balanced from v3.1
//   6. Breakeven: 1.0x ATR — protect capital early
//   7. Cooldown: 3 bars (from 5) — confluence 5 is already selective
//   8. Bear close: >= 5, min hold 4 bars, NO Supertrend close
//
//   KEPT:
//   - SL: 1.5x ATR (proven across all versions)
//   - Longs only, vol 1.5x, HTF 4H EMA50, $100 capital
//
//   Expected effect: Fewer trades but much higher quality entries.
//   Larger position size amplifies winners. ADX filter avoids
//   choppy/ranging markets where confluence signals are noise.
//
// Confluence factors:
//   Bull (max 9): EMA ribbon, RSI, MACD hist, Supertrend, BB, VWAP+Cloud,
//                 Fibonacci, Banker Fund Flow (L3), MACD Divergence (L2)
//   Bear (max 8): EMA ribbon, RSI, MACD hist, Supertrend, BB, VWAP+Cloud,
//                 Fibonacci, MACD Divergence (L2)
// =============================================================================

//@version=5
strategy("SOL Confluence Pro v3.5", overlay=true, default_qty_type=strategy.percent_of_equity,
     default_qty_value=25, initial_capital=100, slippage=3, commission_type=strategy.commission.percent,
     commission_value=0.1, pyramiding=0, calc_on_every_tick=false)

// =============================================================================
// INPUTS
// =============================================================================

grp_wh = "Signal"
min_confluence = input.int(5, "Min Confluence (bull /9, bear /8)", minval=2, maxval=9, group=grp_wh)

grp_ma = "Moving Averages"
ema_fast   = input.int(9,   "EMA Fast",  group=grp_ma)
ema_mid    = input.int(21,  "EMA Mid",   group=grp_ma)
ema_slow   = input.int(50,  "EMA Slow",  group=grp_ma)
sma_200    = input.int(200, "SMA 200",   group=grp_ma)

grp_rsi = "RSI"
rsi_len = input.int(14,   "RSI Length",      group=grp_rsi)
rsi_ob  = input.float(70, "RSI Overbought",  group=grp_rsi)
rsi_os  = input.float(30, "RSI Oversold",    group=grp_rsi)

grp_macd = "MACD"
macd_fast   = input.int(12, "Fast",   group=grp_macd)
macd_slow   = input.int(26, "Slow",   group=grp_macd)
macd_signal = input.int(9,  "Signal", group=grp_macd)

grp_st = "Supertrend"
st_factor  = input.float(3.0, "Factor",     group=grp_st)
st_atr_len = input.int(10,    "ATR Length", group=grp_st)

grp_bb = "Bollinger Bands"
bb_len  = input.int(20,    "Length",     group=grp_bb)
bb_mult = input.float(2.0, "Multiplier", group=grp_bb)

grp_ichi = "Ichimoku"
ichi_tenkan   = input.int(9,  "Tenkan",   group=grp_ichi)
ichi_kijun    = input.int(26, "Kijun",    group=grp_ichi)
ichi_senkou_b = input.int(52, "Senkou B", group=grp_ichi)

grp_vol = "Volume"
vol_ma_len      = input.int(20,   "MA Length",         group=grp_vol)
vol_spike_mult  = input.float(1.5,"Spike Multiplier",  group=grp_vol)

grp_htf = "Higher Timeframe"
htf_tf      = input.timeframe("240", "Timeframe",  group=grp_htf)
htf_ema_len = input.int(50,  "EMA Length",           group=grp_htf)

grp_adx = "ADX Trend Filter"
adx_len       = input.int(14,   "ADX Length",    group=grp_adx)
adx_threshold = input.float(20, "ADX Minimum",   group=grp_adx, tooltip="Only enter trades when ADX > this value (trending market)")

grp_risk = "Risk Management"
sl_atr_mult    = input.float(1.5, "Stop Loss ATR Multiplier",   group=grp_risk)
tp_atr_mult    = input.float(3.5, "Take Profit ATR Multiplier", group=grp_risk)
risk_per_trade = input.float(2.0, "Risk Per Trade %", minval=0.5, maxval=10, group=grp_risk)

grp_trail = "Trailing Stop"
trail_activate_mult = input.float(1.5, "Activate After ATR Move",  group=grp_trail, tooltip="Trail activates once price moves this many ATRs in your favor")
trail_offset_mult   = input.float(1.0, "Trail Offset ATR",         group=grp_trail, tooltip="Once active, trail stop follows price at this many ATRs distance")
breakeven_mult      = input.float(1.0, "Move SL to Breakeven After ATR", group=grp_trail, tooltip="After this much profit in ATRs, move stop to entry price")

grp_close = "Close Conditions"
close_bear_threshold = input.int(5,  "Bear Score to Close Long", minval=3, maxval=8, group=grp_close, tooltip="Close on strong reversal signal")
close_bull_threshold = input.int(5,  "Bull Score to Close Short", minval=3, maxval=9, group=grp_close)
min_hold_bars        = input.int(4,  "Min Hold Bars Before Close", minval=1, maxval=24, group=grp_close)

grp_short = "Short Control"
short_enabled      = input.bool(false, "Enable Short Signals", group=grp_short)
short_bear_bars    = input.int(50, "Bars Below SMA200 Required", minval=5, maxval=200, group=grp_short)

grp_cool = "Cooldown"
cooldown_bars = input.int(3, "Bars Between Signals", minval=0, maxval=50, group=grp_cool)

// =============================================================================
// HELPER: Weighted Simple Average (used by Banker Fund Flow)
// =============================================================================

_wsa(src, length, weight) =>
    s   = 0.0
    ma  = 0.0
    out = 0.0
    s   := nz(s[1]) - nz(src[length]) + src
    ma  := na(src[length]) ? na : s / length
    out := na(out[1]) ? ma : (src * weight + out[1] * (length - weight)) / length
    out

// =============================================================================
// CALCULATIONS
// =============================================================================

ema9   = ta.ema(close, ema_fast)
ema21  = ta.ema(close, ema_mid)
ema50  = ta.ema(close, ema_slow)
sma200 = ta.sma(close, sma_200)

rsi_val = ta.rsi(close, rsi_len)
[macd_line, signal_line, macd_hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)
[st_line, st_dir] = ta.supertrend(st_factor, st_atr_len)
[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_len, bb_mult)

// VWAP — use previous confirmed bar to avoid repainting
vwap_val = ta.vwap(hlc3)[1]

// Ichimoku
tenkan   = (ta.highest(high, ichi_tenkan)   + ta.lowest(low, ichi_tenkan))   / 2
kijun    = (ta.highest(high, ichi_kijun)    + ta.lowest(low, ichi_kijun))    / 2
senkou_a = (tenkan + kijun) / 2
senkou_b = (ta.highest(high, ichi_senkou_b) + ta.lowest(low, ichi_senkou_b)) / 2
cloud_top    = math.max(senkou_a[26], senkou_b[26])
cloud_bottom = math.min(senkou_a[26], senkou_b[26])

// Volume
vol_ma    = ta.sma(volume, vol_ma_len)
vol_spike = volume > vol_ma * vol_spike_mult

// ATR
atr_val = ta.atr(14)

// ADX — trend strength filter (v3.5 addition)
// DMI calculation
up_move   = high - high[1]
down_move = low[1] - low
plus_dm   = (up_move > down_move and up_move > 0) ? up_move : 0.0
minus_dm  = (down_move > up_move and down_move > 0) ? down_move : 0.0
true_range = ta.atr(1)
plus_di   = 100 * ta.rma(plus_dm, adx_len) / ta.rma(true_range, adx_len)
minus_di  = 100 * ta.rma(minus_dm, adx_len) / ta.rma(true_range, adx_len)
dx        = 100 * math.abs(plus_di - minus_di) / (plus_di + minus_di)
adx_val   = ta.rma(dx, adx_len)
adx_trending = adx_val > adx_threshold

// HTF — 4H EMA50
htf_ema   = request.security(syminfo.tickerid, htf_tf, ta.ema(close, htf_ema_len)[1], lookahead=barmerge.lookahead_off)
htf_close = request.security(syminfo.tickerid, htf_tf, close[1],                      lookahead=barmerge.lookahead_off)
htf_bullish = htf_close > htf_ema
htf_bearish = htf_close < htf_ema

// Fibonacci (50-bar swing)
swing_high = ta.highest(high, 50)
swing_low  = ta.lowest(low,   50)
fib_range  = swing_high - swing_low
fib_382 = swing_high - fib_range * 0.382
fib_500 = swing_high - fib_range * 0.500
fib_618 = swing_high - fib_range * 0.618
near_fib = (close <= fib_618 * 1.01 and close >= fib_618 * 0.99) or
           (close <= fib_500 * 1.01 and close >= fib_500 * 0.99) or
           (close <= fib_382 * 1.01 and close >= fib_382 * 0.99)

// --- L3 Banker Fund Flow (blackcat) ---
bff_pct  = (close - ta.lowest(low, 27)) / (ta.highest(high, 27) - ta.lowest(low, 27)) * 100
bff_wsa1 = _wsa(bff_pct, 5, 1)
fund_flow_trend = (3 * bff_wsa1 - 2 * _wsa(bff_wsa1, 3, 1) - 50) * 1.032 + 50
bff_typical  = (2 * close + high + low + open) / 5
bull_bear_line = ta.ema((bff_typical - ta.lowest(low, 34)) / (ta.highest(high, 34) - ta.lowest(low, 34)) * 100, 13)
banker_entry = ta.crossover(fund_flow_trend, bull_bear_line) and bull_bear_line < 25

// --- L2 MACD Divergence (blackcat) ---
bars_since_cross_up   = ta.barssince(ta.crossover(macd_line, signal_line)[1])
bars_since_cross_down = ta.barssince(ta.crossunder(macd_line, signal_line)[1])
macd_div_bull = (close[bars_since_cross_up + 1] > close) and
               (macd_line > macd_line[bars_since_cross_up + 1]) and
               ta.crossover(macd_line, signal_line)
macd_div_bear = (close[bars_since_cross_down + 1] < close) and
               (macd_line[bars_since_cross_down + 1] > macd_line) and
               ta.crossunder(macd_line, signal_line)

// --- Bear Market Gate ---
var int bars_below_sma200 = 0
bars_below_sma200 := close < sma200 ? bars_below_sma200 + 1 : 0
bear_market = bars_below_sma200 >= short_bear_bars
short_allowed = short_enabled and bear_market

// --- Cooldown Timer ---
var int bars_since_signal = 100
bars_since_signal := bars_since_signal + 1
cooldown_ok = bars_since_signal >= cooldown_bars

// =============================================================================
// CONFLUENCE SCORES
// =============================================================================

ema_bull = ema9 > ema21 and ema21 > ema50 and close > sma200
ema_bear = ema9 < ema21 and ema21 < ema50 and close < sma200

rsi_bull = ta.crossover(rsi_val, rsi_os)  or (rsi_val > 40 and rsi_val < 65 and rsi_val > rsi_val[1])
rsi_bear = ta.crossunder(rsi_val, rsi_ob) or (rsi_val < 60 and rsi_val > 35 and rsi_val < rsi_val[1])

macd_bull = macd_hist > 0 and macd_hist > macd_hist[1]
macd_bear = macd_hist < 0 and macd_hist < macd_hist[1]

st_bull = st_dir < 0
st_bear = st_dir > 0

bb_bull = close < bb_mid and close > bb_lower and close > close[1]
bb_bear = close > bb_mid and close < bb_upper and close < close[1]

vi_bull = close > vwap_val and close > cloud_top
vi_bear = close < vwap_val and close < cloud_bottom

fib_bull = near_fib and close > close[1]
fib_bear = near_fib and close < close[1]

// Bull max = 9, Bear max = 8
bull_score = (ema_bull      ? 1 : 0) + (rsi_bull      ? 1 : 0) + (macd_bull     ? 1 : 0) +
             (st_bull       ? 1 : 0) + (bb_bull       ? 1 : 0) + (vi_bull       ? 1 : 0) +
             (fib_bull      ? 1 : 0) + (banker_entry  ? 1 : 0) + (macd_div_bull ? 1 : 0)

bear_score = (ema_bear      ? 1 : 0) + (rsi_bear      ? 1 : 0) + (macd_bear     ? 1 : 0) +
             (st_bear       ? 1 : 0) + (bb_bear       ? 1 : 0) + (vi_bear       ? 1 : 0) +
             (fib_bear      ? 1 : 0) + (macd_div_bear ? 1 : 0)

// =============================================================================
// SIGNALS (v3.5: confluence >= 5 + ADX trending filter)
// =============================================================================

long_signal  = bull_score >= min_confluence and vol_spike and htf_bullish and cooldown_ok and adx_trending
short_signal = bear_score >= min_confluence and vol_spike and htf_bearish and cooldown_ok and short_allowed and adx_trending

// Reset cooldown on signal fire
if long_signal or short_signal
    bars_since_signal := 0

// --- Position Tracking ---
var bool  in_long        = false
var bool  in_short       = false
var float entry_price    = na
var float entry_atr      = na
var int   bars_in_trade  = 0
var bool  at_breakeven   = false

// Count bars since entry
bars_in_trade := (in_long or in_short) ? bars_in_trade + 1 : 0

// --- Breakeven Stop (at 1.0x ATR — protect capital early) ---
if in_long and not at_breakeven and not na(entry_price) and not na(entry_atr)
    if close >= entry_price + entry_atr * breakeven_mult
        trail_offset_be  = entry_atr * trail_offset_mult / syminfo.mintick
        activate_dist_be = entry_atr * trail_activate_mult / syminfo.mintick
        strategy.exit("Long Exit", "Long", stop=entry_price, limit=entry_price + entry_atr * tp_atr_mult,
                      trail_points=activate_dist_be, trail_offset=trail_offset_be)
        at_breakeven := true

if in_short and not at_breakeven and not na(entry_price) and not na(entry_atr)
    if close <= entry_price - entry_atr * breakeven_mult
        trail_offset_be  = entry_atr * trail_offset_mult / syminfo.mintick
        activate_dist_be = entry_atr * trail_activate_mult / syminfo.mintick
        strategy.exit("Short Exit", "Short", stop=entry_price, limit=entry_price - entry_atr * tp_atr_mult,
                      trail_points=activate_dist_be, trail_offset=trail_offset_be)
        at_breakeven := true

// --- Close Conditions (bear >= 5, NO Supertrend close) ---
close_long_confluence  = bear_score >= close_bear_threshold and bars_in_trade >= min_hold_bars
close_short_confluence = bull_score >= close_bull_threshold and bars_in_trade >= min_hold_bars

close_long  = close_long_confluence
close_short = close_short_confluence

// Confidence (bull out of 9, bear out of 8)
long_conf  = math.min(100, math.round(bull_score / 9.0 * 60 + (vol_spike ? 20 : 0) + (htf_bullish ? 20 : 0)))
short_conf = math.min(100, math.round(bear_score / 8.0 * 60 + (vol_spike ? 20 : 0) + (htf_bearish ? 20 : 0)))

calc_lev(c)  => c >= 85 ? 5 : c >= 70 ? 3 : c >= 55 ? 2 : 1
calc_size(c) => c >= 85 ? 15.0 : c >= 70 ? 10.0 : c >= 55 ? 7.0 : 5.0

// =============================================================================
// STRATEGY EXECUTION (for backtesting)
// =============================================================================

if long_signal and not in_long
    entry_price   := close
    entry_atr     := atr_val
    bars_in_trade := 0
    at_breakeven  := false

    sl = close - atr_val * sl_atr_mult
    tp = close + atr_val * tp_atr_mult

    trail_offset_e  = atr_val * trail_offset_mult / syminfo.mintick
    activate_dist_e = atr_val * trail_activate_mult / syminfo.mintick

    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=sl, limit=tp,
                  trail_points=activate_dist_e, trail_offset=trail_offset_e)
    in_long  := true
    in_short := false

if short_signal and not in_short
    entry_price   := close
    entry_atr     := atr_val
    bars_in_trade := 0
    at_breakeven  := false

    sl = close + atr_val * sl_atr_mult
    tp = close - atr_val * tp_atr_mult

    trail_offset_e  = atr_val * trail_offset_mult / syminfo.mintick
    activate_dist_e = atr_val * trail_activate_mult / syminfo.mintick

    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=sl, limit=tp,
                  trail_points=activate_dist_e, trail_offset=trail_offset_e)
    in_short := true
    in_long  := false

if close_long and in_long
    strategy.close("Long")
    in_long       := false
    entry_price   := na
    entry_atr     := na
    bars_in_trade := 0
    at_breakeven  := false

if close_short and in_short
    strategy.close("Short")
    in_short      := false
    entry_price   := na
    entry_atr     := na
    bars_in_trade := 0
    at_breakeven  := false

// =============================================================================
// VISUALS
// =============================================================================

plot(ema9,   "EMA 9",   color=color.new(color.lime,   30), linewidth=1)
plot(ema21,  "EMA 21",  color=color.new(color.yellow, 30), linewidth=1)
plot(ema50,  "EMA 50",  color=color.new(color.orange, 30), linewidth=2)
plot(sma200, "SMA 200", color=color.new(color.red,    30), linewidth=2)
plot(st_line, "Supertrend", color=st_dir < 0 ? color.green : color.red, linewidth=2, style=plot.style_linebr)

plotshape(banker_entry, "Banker Entry", shape.triangleup, location.belowbar, color.new(color.teal, 20), size=size.tiny)
plotshape(long_signal and not in_long[1], "BUY", shape.triangleup, location.belowbar, color.lime, size=size.normal)
plotshape(short_signal and not in_short[1], "SELL", shape.triangledown, location.abovebar, color.red, size=size.normal)
plotshape(close_long and in_long, "CLOSE L", shape.xcross, location.belowbar, color.yellow, size=size.small)
plotshape(close_short and in_short, "CLOSE S", shape.xcross, location.abovebar, color.yellow, size=size.small)

// Bear market zone shading
bgcolor(bear_market and short_enabled ? color.new(color.red, 95) : na, title="Bear Market Zone")

// ADX trending zone
bgcolor(adx_trending ? color.new(color.blue, 96) : na, title="ADX Trending")

// Breakeven level
plot(in_long and not na(entry_price) ? entry_price : na,
     "Breakeven", color=at_breakeven ? color.new(color.white, 30) : color.new(color.white, 80), style=plot.style_linebr, linewidth=1)
// Trailing stop activation zone
plot(in_long and not na(entry_price) ? entry_price + entry_atr * trail_activate_mult : na,
     "Trail Activate", color=color.new(color.aqua, 60), style=plot.style_linebr, linewidth=1)

// Info table
var table t = table.new(position.top_right, 2, 12, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "Bull",       text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, str.tostring(bull_score) + "/9", text_color=bull_score >= min_confluence ? color.lime : color.gray, text_size=size.small)
    table.cell(t, 0, 1, "Bear",       text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(bear_score) + "/8", text_color=bear_score >= min_confluence ? color.red : color.gray, text_size=size.small)
    table.cell(t, 0, 2, "RSI",        text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(math.round(rsi_val, 1)), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 3, "ADX",        text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(math.round(adx_val, 1)), text_color=adx_trending ? color.lime : color.gray, text_size=size.small)
    table.cell(t, 0, 4, "HTF 4H50",   text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, htf_bullish ? "BULL" : "BEAR", text_color=htf_bullish ? color.lime : color.red, text_size=size.small)
    table.cell(t, 0, 5, "Vol Spike",  text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, vol_spike ? "YES" : "NO", text_color=vol_spike ? color.lime : color.gray, text_size=size.small)
    table.cell(t, 0, 6, "Banker",     text_color=color.white, text_size=size.small)
    table.cell(t, 1, 6, banker_entry ? "ENTRY" : "-", text_color=banker_entry ? color.teal : color.gray, text_size=size.small)
    table.cell(t, 0, 7, "MACD Div",   text_color=color.white, text_size=size.small)
    table.cell(t, 1, 7, macd_div_bull ? "BULL" : macd_div_bear ? "BEAR" : "-", text_color=macd_div_bull ? color.lime : macd_div_bear ? color.red : color.gray, text_size=size.small)
    table.cell(t, 0, 8, "Bear Mkt",   text_color=color.white, text_size=size.small)
    table.cell(t, 1, 8, bear_market ? "YES (" + str.tostring(bars_below_sma200) + ")" : "NO", text_color=bear_market ? color.red : color.gray, text_size=size.small)
    table.cell(t, 0, 9, "Cooldown",   text_color=color.white, text_size=size.small)
    table.cell(t, 1, 9, cooldown_ok ? "READY" : str.tostring(cooldown_bars - bars_since_signal) + " bars", text_color=cooldown_ok ? color.lime : color.yellow, text_size=size.small)
    table.cell(t, 0, 10, "In Trade",   text_color=color.white, text_size=size.small)
    trade_lbl = in_long ? "LONG " + str.tostring(bars_in_trade) + (at_breakeven ? " BE" : "") : in_short ? "SHORT " + str.tostring(bars_in_trade) + (at_breakeven ? " BE" : "") : "-"
    table.cell(t, 1, 10, trade_lbl, text_color=in_long ? color.lime : in_short ? color.red : color.gray, text_size=size.small)
    table.cell(t, 0, 11, "Confidence", text_color=color.white, text_size=size.small)
    best_conf = bull_score > bear_score ? long_conf : short_conf
    table.cell(t, 1, 11, str.tostring(best_conf) + "%", text_color=best_conf >= 70 ? color.lime : best_conf >= 50 ? color.yellow : color.gray, text_size=size.small)
