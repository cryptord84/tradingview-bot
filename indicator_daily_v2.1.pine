// =============================================================================
// Confluence Pro v2.1 — DAILY ALERT INDICATOR (Multi-Token)
//
// Built directly from backtest_daily_confluence_v2.pine (PF 2.336 on SOL)
// Version bump to v2.1 for clean multi-token deployment.
//
// 9-factor confluence system for daily timeframe.
// Shorts restricted to sustained bear markets only.
//
// Profitable tokens (backtested):
//   SOL (PF 2.336) — other tokens had <4 trades over 5yr, not viable
//   SOL ONLY recommended for Daily timeframe
//
// Entry:
//   Bull confluence >= 5/9 + Volume spike 2.0x + HTF Daily EMA200 bullish
//   + 10-bar cooldown between signals
//
// Exit (handled by position monitor):
//   TP 5x ATR / SL 1.5x ATR
//
// Confluence factors:
//   Bull (max 9): EMA ribbon, RSI, MACD hist, Supertrend, BB, VWAP+Cloud,
//                 Fibonacci, Banker Fund Flow (L3), MACD Divergence (L2)
//   Bear (max 8): EMA ribbon, RSI, MACD hist, Supertrend, BB, VWAP+Cloud,
//                 Fibonacci, MACD Divergence (L2)
//
// SETUP:
//   1. Open TradingView -> SOLUSDT -> Daily timeframe
//   2. Pine Editor -> paste this -> Add to chart
//   3. Set your webhook secret in indicator settings
//   4. Create alert: Condition = this indicator -> "Any alert() function call"
//   5. Webhook URL: https://your-bot-url/webhook
//   6. Expiration: max allowed, set calendar reminder to renew
// =============================================================================

//@version=5
indicator("Confluence Pro v2.1 — Daily Alerts", overlay=true, max_bars_back=500)

// =============================================================================
// INPUTS
// =============================================================================

grp_wh = "Webhook"
webhook_secret = input.string("CHANGE_ME", "Webhook Secret", group=grp_wh)
min_confluence = input.int(5, "Min Confluence (bull /9, bear /8)", minval=2, maxval=9, group=grp_wh)

grp_ma = "Moving Averages"
ema_fast   = input.int(9,   "EMA Fast",  group=grp_ma)
ema_mid    = input.int(21,  "EMA Mid",   group=grp_ma)
ema_slow   = input.int(50,  "EMA Slow",  group=grp_ma)
sma_200    = input.int(200, "SMA 200",   group=grp_ma)

grp_rsi = "RSI"
rsi_len = input.int(14,   "RSI Length",      group=grp_rsi)
rsi_ob  = input.float(70, "RSI Overbought",  group=grp_rsi)
rsi_os  = input.float(30, "RSI Oversold",    group=grp_rsi)

grp_macd = "MACD"
macd_fast   = input.int(12, "Fast",   group=grp_macd)
macd_slow   = input.int(26, "Slow",   group=grp_macd)
macd_signal = input.int(9,  "Signal", group=grp_macd)

grp_st = "Supertrend"
st_factor  = input.float(3.0, "Factor",     group=grp_st)
st_atr_len = input.int(10,    "ATR Length", group=grp_st)

grp_bb = "Bollinger Bands"
bb_len  = input.int(20,    "Length",     group=grp_bb)
bb_mult = input.float(2.0, "Multiplier", group=grp_bb)

grp_ichi = "Ichimoku"
ichi_tenkan   = input.int(9,  "Tenkan",   group=grp_ichi)
ichi_kijun    = input.int(26, "Kijun",    group=grp_ichi)
ichi_senkou_b = input.int(52, "Senkou B", group=grp_ichi)

grp_vol = "Volume"
vol_ma_len      = input.int(20,   "MA Length",         group=grp_vol)
vol_spike_mult  = input.float(2.0,"Spike Multiplier",  group=grp_vol)

grp_htf = "Higher Timeframe"
htf_tf      = input.timeframe("D", "Timeframe",  group=grp_htf)
htf_ema_len = input.int(200, "EMA Length",         group=grp_htf)

grp_short = "Short Control"
short_enabled      = input.bool(true, "Enable Short Signals", group=grp_short)
short_bear_bars    = input.int(20, "Bars Below SMA200 Required", minval=5, maxval=100, group=grp_short)

grp_cool = "Cooldown"
cooldown_bars = input.int(10, "Bars Between Signals", minval=0, maxval=50, group=grp_cool)

// =============================================================================
// HELPER: Weighted Simple Average (used by Banker Fund Flow)
// =============================================================================

_wsa(src, length, weight) =>
    s   = 0.0
    ma  = 0.0
    out = 0.0
    s   := nz(s[1]) - nz(src[length]) + src
    ma  := na(src[length]) ? na : s / length
    out := na(out[1]) ? ma : (src * weight + out[1] * (length - weight)) / length
    out

// =============================================================================
// CALCULATIONS
// =============================================================================

ema9   = ta.ema(close, ema_fast)
ema21  = ta.ema(close, ema_mid)
ema50  = ta.ema(close, ema_slow)
sma200 = ta.sma(close, sma_200)

rsi_val = ta.rsi(close, rsi_len)
[macd_line, signal_line, macd_hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)
[st_line, st_dir] = ta.supertrend(st_factor, st_atr_len)
[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_len, bb_mult)

// VWAP — use previous confirmed bar to avoid repainting
vwap_val = ta.vwap(hlc3)[1]

// Ichimoku
tenkan   = (ta.highest(high, ichi_tenkan)   + ta.lowest(low, ichi_tenkan))   / 2
kijun    = (ta.highest(high, ichi_kijun)    + ta.lowest(low, ichi_kijun))    / 2
senkou_a = (tenkan + kijun) / 2
senkou_b = (ta.highest(high, ichi_senkou_b) + ta.lowest(low, ichi_senkou_b)) / 2
cloud_top    = math.max(senkou_a[26], senkou_b[26])
cloud_bottom = math.min(senkou_a[26], senkou_b[26])

// Volume (v2: raised default from 1.5x to 2.0x)
vol_ma    = ta.sma(volume, vol_ma_len)
vol_spike = volume > vol_ma * vol_spike_mult

// ATR
atr_val = ta.atr(14)

// HTF — Daily EMA200
htf_ema   = request.security(syminfo.tickerid, htf_tf, ta.ema(close, htf_ema_len)[1], lookahead=barmerge.lookahead_off)
htf_close = request.security(syminfo.tickerid, htf_tf, close[1],                      lookahead=barmerge.lookahead_off)
htf_bullish = htf_close > htf_ema
htf_bearish = htf_close < htf_ema

// Fibonacci (50-bar swing)
swing_high = ta.highest(high, 50)
swing_low  = ta.lowest(low,   50)
fib_range  = swing_high - swing_low
fib_382 = swing_high - fib_range * 0.382
fib_500 = swing_high - fib_range * 0.500
fib_618 = swing_high - fib_range * 0.618
near_fib = (close <= fib_618 * 1.01 and close >= fib_618 * 0.99) or
           (close <= fib_500 * 1.01 and close >= fib_500 * 0.99) or
           (close <= fib_382 * 1.01 and close >= fib_382 * 0.99)

// --- L3 Banker Fund Flow (blackcat) ---
bff_pct  = (close - ta.lowest(low, 27)) / (ta.highest(high, 27) - ta.lowest(low, 27)) * 100
bff_wsa1 = _wsa(bff_pct, 5, 1)
fund_flow_trend = (3 * bff_wsa1 - 2 * _wsa(bff_wsa1, 3, 1) - 50) * 1.032 + 50
bff_typical  = (2 * close + high + low + open) / 5
bull_bear_line = ta.ema((bff_typical - ta.lowest(low, 34)) / (ta.highest(high, 34) - ta.lowest(low, 34)) * 100, 13)
banker_entry = ta.crossover(fund_flow_trend, bull_bear_line) and bull_bear_line < 25

// --- L2 MACD Divergence (blackcat) ---
bars_since_cross_up   = ta.barssince(ta.crossover(macd_line, signal_line)[1])
bars_since_cross_down = ta.barssince(ta.crossunder(macd_line, signal_line)[1])
macd_div_bull = (close[bars_since_cross_up + 1] > close) and
               (macd_line > macd_line[bars_since_cross_up + 1]) and
               ta.crossover(macd_line, signal_line)
macd_div_bear = (close[bars_since_cross_down + 1] < close) and
               (macd_line[bars_since_cross_down + 1] > macd_line) and
               ta.crossunder(macd_line, signal_line)

// --- Bear Market Gate ---
var int bars_below_sma200 = 0
bars_below_sma200 := close < sma200 ? bars_below_sma200 + 1 : 0
bear_market = bars_below_sma200 >= short_bear_bars
short_allowed = short_enabled and bear_market

// --- Cooldown Timer ---
var int bars_since_signal = 100
bars_since_signal := bars_since_signal + 1
cooldown_ok = bars_since_signal >= cooldown_bars

// =============================================================================
// CONFLUENCE SCORES
// =============================================================================

ema_bull = ema9 > ema21 and ema21 > ema50 and close > sma200
ema_bear = ema9 < ema21 and ema21 < ema50 and close < sma200

rsi_bull = ta.crossover(rsi_val, rsi_os)  or (rsi_val > 40 and rsi_val < 65 and rsi_val > rsi_val[1])
rsi_bear = ta.crossunder(rsi_val, rsi_ob) or (rsi_val < 60 and rsi_val > 35 and rsi_val < rsi_val[1])

macd_bull = macd_hist > 0 and macd_hist > macd_hist[1]
macd_bear = macd_hist < 0 and macd_hist < macd_hist[1]

st_bull = st_dir < 0
st_bear = st_dir > 0

bb_bull = close < bb_mid and close > bb_lower and close > close[1]
bb_bear = close > bb_mid and close < bb_upper and close < close[1]

vi_bull = close > vwap_val and close > cloud_top
vi_bear = close < vwap_val and close < cloud_bottom

fib_bull = near_fib and close > close[1]
fib_bear = near_fib and close < close[1]

// Bull max = 9, Bear max = 8
bull_score = (ema_bull      ? 1 : 0) + (rsi_bull      ? 1 : 0) + (macd_bull     ? 1 : 0) +
             (st_bull       ? 1 : 0) + (bb_bull       ? 1 : 0) + (vi_bull       ? 1 : 0) +
             (fib_bull      ? 1 : 0) + (banker_entry  ? 1 : 0) + (macd_div_bull ? 1 : 0)

bear_score = (ema_bear      ? 1 : 0) + (rsi_bear      ? 1 : 0) + (macd_bear     ? 1 : 0) +
             (st_bear       ? 1 : 0) + (bb_bear       ? 1 : 0) + (vi_bear       ? 1 : 0) +
             (fib_bear      ? 1 : 0) + (macd_div_bear ? 1 : 0)

// =============================================================================
// SIGNALS (cooldown + bear market gate for shorts)
// =============================================================================

long_signal  = bull_score >= min_confluence and vol_spike and htf_bullish and cooldown_ok and barstate.isconfirmed
short_signal = bear_score >= min_confluence and vol_spike and htf_bearish and cooldown_ok and short_allowed and barstate.isconfirmed

// Close conditions (for webhook notification)
close_long  = (bear_score >= 3 or ta.crossunder(ema9, ema50) or st_dir > 0) and barstate.isconfirmed
close_short = (bull_score >= 3 or ta.crossover(ema9, ema50) or st_dir < 0) and barstate.isconfirmed

// Reset cooldown on signal fire
if long_signal or short_signal
    bars_since_signal := 0

// Confidence (bull out of 9, bear out of 8)
long_conf  = math.min(100, math.round(bull_score / 9.0 * 60 + (vol_spike ? 20 : 0) + (htf_bullish ? 20 : 0)))
short_conf = math.min(100, math.round(bear_score / 8.0 * 60 + (vol_spike ? 20 : 0) + (htf_bearish ? 20 : 0)))

calc_lev(c)  => c >= 85 ? 5 : c >= 70 ? 3 : c >= 55 ? 2 : 1
calc_size(c) => c >= 85 ? 15.0 : c >= 70 ? 10.0 : c >= 55 ? 7.0 : 5.0

// =============================================================================
// ALERT CONDITIONS
// =============================================================================

alertcondition(long_signal,  "BUY Signal",   "BUY")
alertcondition(short_signal, "SELL Signal",  "SELL")
alertcondition(close_long,   "CLOSE Long",   "CLOSE")

// =============================================================================
// ALERT MESSAGES (webhook JSON payloads)
// =============================================================================

if long_signal
    alert('{"secret":"' + webhook_secret + '","signal_type":"BUY","symbol":"' + syminfo.ticker +
         '","entry_price_estimate":' + str.tostring(close) +
         ',"confidence_score":' + str.tostring(long_conf) +
         ',"suggested_leverage":' + str.tostring(calc_lev(long_conf)) +
         ',"suggested_position_size_percent":' + str.tostring(calc_size(long_conf)) +
         ',"bull_score":' + str.tostring(bull_score) +
         ',"bear_score":' + str.tostring(bear_score) +
         ',"banker_entry":' + str.tostring(banker_entry ? 1 : 0) +
         ',"macd_divergence":' + str.tostring(macd_div_bull ? 1 : 0) +
         ',"rsi":' + str.tostring(math.round(rsi_val, 2)) +
         ',"atr":' + str.tostring(math.round(atr_val, 4)) +
         ',"timeframe":"' + timeframe.period + '"}',
         alert.freq_once_per_bar_close)

if short_signal
    alert('{"secret":"' + webhook_secret + '","signal_type":"SELL","symbol":"' + syminfo.ticker +
         '","entry_price_estimate":' + str.tostring(close) +
         ',"confidence_score":' + str.tostring(short_conf) +
         ',"suggested_leverage":' + str.tostring(calc_lev(short_conf)) +
         ',"suggested_position_size_percent":' + str.tostring(calc_size(short_conf)) +
         ',"bull_score":' + str.tostring(bull_score) +
         ',"bear_score":' + str.tostring(bear_score) +
         ',"banker_entry":0' +
         ',"macd_divergence":' + str.tostring(macd_div_bear ? 1 : 0) +
         ',"rsi":' + str.tostring(math.round(rsi_val, 2)) +
         ',"atr":' + str.tostring(math.round(atr_val, 4)) +
         ',"timeframe":"' + timeframe.period + '"}',
         alert.freq_once_per_bar_close)

if close_long
    alert('{"secret":"' + webhook_secret + '","signal_type":"CLOSE","symbol":"' + syminfo.ticker +
         '","entry_price_estimate":' + str.tostring(close) +
         ',"confidence_score":0,"suggested_leverage":1,"suggested_position_size_percent":0' +
         ',"bull_score":' + str.tostring(bull_score) +
         ',"bear_score":' + str.tostring(bear_score) +
         ',"banker_entry":0,"macd_divergence":0' +
         ',"rsi":' + str.tostring(math.round(rsi_val, 2)) +
         ',"atr":' + str.tostring(math.round(atr_val, 4)) +
         ',"timeframe":"' + timeframe.period + '"}',
         alert.freq_once_per_bar_close)

// =============================================================================
// VISUALS
// =============================================================================

plot(ema9,   "EMA 9",   color=color.new(color.lime,   30), linewidth=1)
plot(ema21,  "EMA 21",  color=color.new(color.yellow, 30), linewidth=1)
plot(ema50,  "EMA 50",  color=color.new(color.orange, 30), linewidth=2)
plot(sma200, "SMA 200", color=color.new(color.red,    30), linewidth=2)
plot(st_line, "Supertrend", color=st_dir < 0 ? color.green : color.red, linewidth=2, style=plot.style_linebr)

plotshape(banker_entry, "Banker Entry", shape.triangleup, location.belowbar, color.new(color.teal, 20), size=size.tiny)
plotshape(long_signal, "BUY", shape.triangleup, location.belowbar, color.lime, size=size.normal, text="BUY")
plotshape(short_signal, "SELL", shape.triangledown, location.abovebar, color.red, size=size.normal, text="SELL")

// Bear market zone shading (where shorts are allowed)
bgcolor(bear_market and short_enabled ? color.new(color.red, 95) : na, title="Bear Market Zone")

// =============================================================================
// INFO TABLE
// =============================================================================

var table t = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(t, 0, 0, "Daily v2.1",  text_color=color.aqua, text_size=size.small)
    table.cell(t, 1, 0, "SOL ONLY", text_color=color.lime, text_size=size.small)
    table.cell(t, 0, 1, "Bull",      text_color=color.white, text_size=size.small)
    table.cell(t, 1, 1, str.tostring(bull_score) + "/9", text_color=bull_score >= min_confluence ? color.lime : color.gray, text_size=size.small)
    table.cell(t, 0, 2, "Bear",      text_color=color.white, text_size=size.small)
    table.cell(t, 1, 2, str.tostring(bear_score) + "/8", text_color=bear_score >= min_confluence ? color.red : color.gray, text_size=size.small)
    table.cell(t, 0, 3, "RSI",       text_color=color.white, text_size=size.small)
    table.cell(t, 1, 3, str.tostring(math.round(rsi_val, 1)), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 4, "HTF D200",  text_color=color.white, text_size=size.small)
    table.cell(t, 1, 4, htf_bullish ? "BULL" : "BEAR", text_color=htf_bullish ? color.lime : color.red, text_size=size.small)
    table.cell(t, 0, 5, "Vol Spike", text_color=color.white, text_size=size.small)
    table.cell(t, 1, 5, vol_spike ? "YES" : "NO", text_color=vol_spike ? color.lime : color.gray, text_size=size.small)
    table.cell(t, 0, 6, "Banker",    text_color=color.white, text_size=size.small)
    table.cell(t, 1, 6, banker_entry ? "ENTRY" : "-", text_color=banker_entry ? color.teal : color.gray, text_size=size.small)
    table.cell(t, 0, 7, "MACD Div",  text_color=color.white, text_size=size.small)
    table.cell(t, 1, 7, macd_div_bull ? "BULL" : macd_div_bear ? "BEAR" : "-", text_color=macd_div_bull ? color.lime : macd_div_bear ? color.red : color.gray, text_size=size.small)
    table.cell(t, 0, 8, "Bear Mkt",  text_color=color.white, text_size=size.small)
    table.cell(t, 1, 8, bear_market ? "YES (" + str.tostring(bars_below_sma200) + ")" : "NO", text_color=bear_market ? color.red : color.gray, text_size=size.small)
    table.cell(t, 0, 9, "Cooldown",  text_color=color.white, text_size=size.small)
    table.cell(t, 1, 9, cooldown_ok ? "READY" : str.tostring(cooldown_bars - bars_since_signal) + " bars", text_color=cooldown_ok ? color.lime : color.yellow, text_size=size.small)
