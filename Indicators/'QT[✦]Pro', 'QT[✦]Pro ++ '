createNdog(float prevClose, float todayOpn, float atrVal, int prevDayBarIdx) =>
    float topVal    = math.max(prevClose, todayOpn)
    float bottomVal = math.min(prevClose, todayOpn)
    float midVal    = (topVal + bottomVal) / 2
    float gapSize   = math.abs(todayOpn - prevClose)
    float q3Val     = bottomVal + (gapSize * 0.75)
    float q1Val     = bottomVal + (gapSize * 0.25)
    
    bool  isBullish = todayOpn > prevClose
    bool passesFilter = showNdogs and passesAtrFilter(gapSize, atrVal, ndogAtrMultiplier) and gapSize > 0
    int leftBar = na(prevDayBarIdx) ? bar_index : prevDayBarIdx
    if passesFilter
        NDOGBox newNdog = NDOGBox.new(isBullish, prevClose, todayOpn, topVal, bottomVal, midVal, q3Val, q1Val, gapSize, leftBar, time, na, false, na, na, na, na, na, true)
        array.push(ndogArray, newNdog)
        while array.size(ndogArray) > maxNdogCount
            NDOGBox oldest = array.shift(ndogArray)
            if not na(oldest.ndogBox)
                box.delete(oldest.ndogBox)
            if not na(oldest.midLine)
                line.delete(oldest.midLine)
            if not na(oldest.q3Line)
                line.delete(oldest.q3Line)
            if not na(oldest.q1Line)
                line.delete(oldest.q1Line)
            if not na(oldest.infoLabel)
                label.delete(oldest.infoLabel)


