getLineStyle(string styleStr) =>
    styleStr == "Solid" ? line.style_solid : styleStr == "Dashed" ? line.style_dashed : line.style_dotted

getLabelSize() =>
    labelSize == "Tiny" ? size.tiny : labelSize == "Small" ? size.small : labelSize == "Normal" ? size.normal : size.large

calcTradingDaysAgo(int creationTimestamp) =>
    int msPerDay = 24 * 60 * 60 * 1000
    int calendarDays = math.floor((time - creationTimestamp) / msPerDay)
    int weeks = math.floor(calendarDays / 7)
    int remainingDays = calendarDays % 7
    int tradingDays = weeks * 5 + math.min(remainingDays, 5)
    math.max(0, tradingDays)

getNwogSubtypeName(int gapType) =>
    if gapType == GAP_VOID_BULL
        "Void Bull"
    else if gapType == GAP_VOID_BEAR
        "Void Bear"
    else if gapType == GAP_OVERLAP_BULL
        "Overlap Bull"
    else if gapType == GAP_OVERLAP_BEAR
        "Overlap Bear"
    else
        ""

buildNwogLabelText(int gapType, int daysAgo) =>
    if labelStyle == "Descriptive"
        "NWOG (" + getNwogSubtypeName(gapType) + "), " + str.tostring(daysAgo) + "d ago"
