method FetchHTFOHLC(CandleSet this, string htf, Candle htfCandle) =>
    if this.asset1.symbol != '' and this.asset1.include
        [ph1, pl1] = request.security(syminfo.tickerid, htf, [high[1], low[1]], lookahead=barmerge.lookahead_on)
        this.asset1.data_open := htfCandle.o
        this.asset1.data_close := htfCandle.c
        this.asset1.data_high := htfCandle.h
        this.asset1.data_low := htfCandle.l
        this.asset1.prev_high := ph1
        this.asset1.prev_low := pl1
        this.asset1.has_data := true
    if this.asset2.symbol != '' and this.asset2.include
        [o2, h2, l2, c2, ph2, pl2] = request.security(this.asset2.symbol, htf, [open, high, low, close, high[1], low[1]], lookahead=barmerge.lookahead_on)
        this.asset2.data_open := o2
        this.asset2.data_close := c2
        this.asset2.data_high := h2
        this.asset2.data_low := l2
        this.asset2.prev_high := ph2
        this.asset2.prev_low := pl2
        this.asset2.has_data := not na(o2)
    if this.asset3.symbol != '' and this.asset3.include
        [o3, h3, l3, c3, ph3, pl3] = request.security(this.asset3.symbol, htf, [open, high, low, close, high[1], low[1]], lookahead=barmerge.lookahead_on)
        this.asset3.data_open := o3
        this.asset3.data_close := c3
        this.asset3.data_high := h3
        this.asset3.data_low := l3
        this.asset3.prev_high := ph3
        this.asset3.prev_low := pl3
        this.asset3.has_data := not na(o3)
    this

method CalculateHTFBullishBearish(CandleSet this) =>
    if this.asset1.has_data
        this.asset1.bullish := this.asset1.invert ? this.asset1.data_close < this.asset1.data_open : this.asset1.data_close > this.asset1.data_open
        this.asset1.bearish := this.asset1.invert ? this.asset1.data_close > this.asset1.data_open : this.asset1.data_close < this.asset1.data_open
    if this.asset2.has_data
        this.asset2.bullish := this.asset2.invert ? this.asset2.data_close < this.asset2.data_open : this.asset2.data_close > this.asset2.data_open
        this.asset2.bearish := this.asset2.invert ? this.asset2.data_close > this.asset2.data_open : this.asset2.data_close < this.asset2.data_open
    if this.asset3.has_data
        this.asset3.bullish := this.asset3.invert ? this.asset3.data_close < this.asset3.data_open : this.asset3.data_close > this.asset3.data_open
        this.asset3.bearish := this.asset3.invert ? this.asset3.data_close > this.asset3.data_open : this.asset3.data_close < this.asset3.data_open
    this

method DetectHTFDivergence(Candle candle, CandleSet this) =>
    candle.divergence12 := this.asset2.has_data and ((this.asset1.bullish and this.asset2.bearish) or (this.asset1.bearish and this.asset2.bullish))
    candle.divergence13 := this.asset3.has_data and ((this.asset1.bullish and this.asset3.bearish) or (this.asset1.bearish and this.asset3.bullish))
    candle.divergence23 := this.asset2.has_data and this.asset3.has_data and ((this.asset2.bullish and this.asset3.bearish) or (this.asset2.bearish and this.asset3.bullish))
    candle.has_divergence := candle.divergence12 or candle.divergence13 or candle.divergence23
    candle.is_bullish_div := this.asset1.bullish
    candle

method DetectTrueSMT(Candle candle, CandleSet this) =>
    candle.has_true_smt_bull := false
    candle.has_true_smt_bear := false
    candle.smt_bear_target_1 := na
    candle.smt_bear_target_2 := na
    candle.smt_bear_target_3 := na
    candle.smt_bull_target_1 := na
    candle.smt_bull_target_2 := na
    candle.smt_bull_target_3 := na

    float c1_h = this.asset1.data_high
    float c1_l = this.asset1.data_low
    float c2_h = this.asset1.prev_high
    float c2_l = this.asset1.prev_low

    bool a2_bull_smt = false
    bool a2_bear_smt = false
    bool a3_bull_smt = false
    bool a3_bear_smt = false

    if this.asset2.has_data and not na(c2_h)
        float a2_h = this.asset2.data_high
        float a2_l = this.asset2.data_low
        float a2_ph = this.asset2.prev_high
        float a2_pl = this.asset2.prev_low
        
        if this.asset2.invert
            a2_h := -this.asset2.data_low
            a2_l := -this.asset2.data_high
            a2_ph := -this.asset2.prev_low
            a2_pl := -this.asset2.prev_high

        // Bullish SMT Logic (Lower Low mismatch)
        if c1_l < c2_l and a2_l > a2_pl
            a2_bull_smt := true
            candle.smt_bull_target_2 := a2_pl // Asset 2 lagging, target to invalidate
        else if c1_l > c2_l and a2_l < a2_pl
            a2_bull_smt := true
            candle.smt_bull_target_1 := c2_l // Asset 1 lagging, target to invalidate

        // Bearish SMT Logic (Higher High mismatch)
        if c1_h > c2_h and a2_h < a2_ph
            a2_bear_smt := true
            candle.smt_bear_target_2 := a2_ph // Asset 2 lagging, target to invalidate
        else if c1_h < c2_h and a2_h > a2_ph
            a2_bear_smt := true
            candle.smt_bear_target_1 := c2_h // Asset 1 lagging, target to invalidate

    if this.asset3.has_data and not na(c2_h)
        float a3_h = this.asset3.data_high
        float a3_l = this.asset3.data_low
        float a3_ph = this.asset3.prev_high
        float a3_pl = this.asset3.prev_low

        if this.asset3.invert
            a3_h := -this.asset3.data_low
            a3_l := -this.asset3.data_high
            a3_ph := -this.asset3.prev_low
            a3_pl := -this.asset3.prev_high

        // Bullish SMT Logic
        if c1_l < c2_l and a3_l > a3_pl
            a3_bull_smt := true
            candle.smt_bull_target_3 := a3_pl
        else if c1_l > c2_l and a3_l < a3_pl
            a3_bull_smt := true
            candle.smt_bull_target_1 := c2_l 

        // Bearish SMT Logic
        if c1_h > c2_h and a3_h < a3_ph
            a3_bear_smt := true
            candle.smt_bear_target_3 := a3_ph
        else if c1_h < c2_h and a3_h > a3_ph
            a3_bear_smt := true
            candle.smt_bear_target_1 := c2_h

    candle.has_true_smt_bull := a2_bull_smt or a3_bull_smt
    candle.has_true_smt_bear := a2_bear_smt or a3_bear_smt
    candle

method DetectHTFPivots(Candle candle, CandleSet this, string htf) =>
    bool has_pivot_1 = false
    bool has_pivot_2 = false
    bool has_pivot_3 = false
      
    if this.candles.size() >= 3
        Candle prev1 = this.candles.get(1)
        Candle prev2 = this.candles.get(2)
        is_pivot_high = prev1.h > prev2.h and prev1.h > candle.h
        is_pivot_low = prev1.l < prev2.l and prev1.l < candle.l
        has_pivot_1 := is_pivot_high or is_pivot_low
      
    if this.asset2.has_data
        pivothigh_2 = request.security(this.asset2.symbol, htf, ta.pivothigh(high, 1, 1), lookahead=barmerge.lookahead_on)
        pivotlow_2 = request.security(this.asset2.symbol, htf, ta.pivotlow(low, 1, 1), lookahead=barmerge.lookahead_on)
        has_pivot_2 := not na(pivothigh_2) or not na(pivotlow_2)
      
    if this.asset3.has_data
        pivothigh_3 = request.security(this.asset3.symbol, htf, ta.pivothigh(high, 1, 1), lookahead=barmerge.lookahead_on)
        pivotlow_3 = request.security(this.asset3.symbol, htf, ta.pivotlow(low, 1, 1), lookahead=barmerge.lookahead_on)
        has_pivot_3 := not na(pivothigh_3) or not na(pivotlow_3)
      
    is_pivot = this.div_settings.precise_mode ? has_pivot_1 : (has_pivot_1 or has_pivot_2 or has_pivot_3)
    candle.is_psp := is_pivot and candle.has_divergence
    candle

method ValidTimeframe(Helper helper, string HTF) =>
    helper.name := HTF
    if timeframe.in_seconds(HTF) >= timeframe.in_seconds('D') and timeframe.in_seconds(HTF) > timeframe.in_seconds()
        true
    else
        n1 = timeframe.in_seconds()
        n2 = timeframe.in_seconds(HTF)
        n3 = n1 % n2
        n1 < n2 and math.round(n2 / n1) == n2 / n1

method RemainingTime(Helper helper, string HTF) =>
    helper.name := HTF
    if barstate.isrealtime
        timeRemaining = (time_close(HTF) - timenow) / 1000
        days = math.floor(timeRemaining / 86400)
        hours = math.floor((timeRemaining - days * 86400) / 3600)
        minutes = math.floor((timeRemaining - days * 86400 - hours * 3600) / 60)
        seconds = math.floor(timeRemaining - days * 86400 - hours * 3600 - minutes * 60)

        r = str.tostring(seconds, '00')
        if minutes > 0 or hours > 0 or days > 0
            r := str.tostring(minutes, '00') + ':' + r
            r
        if hours > 0 or days > 0
            r := str.tostring(hours, '00') + ':' + r
            r
        if days > 0
            r := str.tostring(days) + 'D ' + r
            r
        r
    else
        'n/a'

method HTFName(Helper helper, string HTF) =>
    helper.name := 'HTFName'
    formatted = HTF
    seconds = timeframe.in_seconds(HTF)
    if seconds < 60
        formatted := str.tostring(seconds) + 's'
    else if seconds / 60 < 60
        formatted := str.tostring(seconds / 60) + 'm'
    else if seconds / 60 / 60 < 24
        formatted := str.tostring(seconds / 60 / 60) + 'H'
    formatted

method HTFEnabled(Helper helper) =>
    helper.name := 'HTFEnabled'
    int enabled = 0
    enabled := enabled + (htf1.settings.show ? 1 : 0)
    enabled := enabled + (htf2.settings.show ? 1 : 0)
    enabled := enabled + (htf3.settings.show ? 1 : 0)
    enabled := enabled + (htf4.settings.show ? 1 : 0)
    enabled := enabled + (htf5.settings.show ? 1 : 0)
    enabled := enabled + (htf6.settings.show ? 1 : 0)
    int last = math.min(enabled, settings.max_sets)
    last

method CandleSetHigh(Helper helper, array<Candle> candles, float h) =>
    helper.name := 'CandlesSetHigh'
    float _h = h
    if array.size(candles) > 0
        for i = 0 to array.size(candles) - 1 by 1
            Candle c = array.get(candles, i)
            if c.h > _h
                _h := c.h
    _h

method CandleSetLow(Helper helper, array<Candle> candles, float l) =>
    helper.name := 'CandlesSetLow'
    float _l = l
    if array.size(candles) > 0
        for i = 0 to array.size(candles) - 1 by 1
            Candle c = array.get(candles, i)
            if c.l < _l
                _l := c.l
    _l

