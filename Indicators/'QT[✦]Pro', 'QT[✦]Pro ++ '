matchAsset(string assetTicker) =>
    if str.length(assetTicker) == 0
        false
    else
        string chartTicker = syminfo.ticker
        string chartTickerId = syminfo.tickerid
        bool isFutures = syminfo.type == "futures"
        bool result = false
        if isFutures
            result := str.contains(chartTickerId, assetTicker) or str.contains(assetTicker, chartTicker)
        else
            result := str.contains(chartTickerId, assetTicker) or str.contains(assetTicker, chartTicker) or str.contains(chartTicker, syminfo.ticker(assetTicker))
        result

