f_add_level_smart(arr, h, l, t_start, t_end, count) =>
    if count > 0
        int t_h_exact = f_find_exact_in_window(h, t_start, t_end, true)
        int t_l_exact = f_find_exact_in_window(l, t_start, t_end, false)
        
        array.unshift(arr, Level.new(l, t_l_exact, false))
        array.unshift(arr, Level.new(h, t_h_exact, true))
        
        while array.size(arr) > (count * 2)
            array.pop(arr)

f_check_mitigation(arr) =>
    if array.size(arr) > 0
        for i = 0 to array.size(arr) - 1
            Level lvl = array.get(arr, i)
            if not lvl.broken
                if lvl.is_high and high > lvl.price
                    lvl.broken := true
                    lvl.stop_time := time[1]
                else if not lvl.is_high and low < lvl.price
                    lvl.broken := true
                    lvl.stop_time := time[1]

