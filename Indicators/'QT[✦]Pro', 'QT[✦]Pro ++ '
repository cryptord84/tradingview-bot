updateNwogExtensions() =>
    bool isOneMinute = timeframe.period == "1"
    if array.size(nwogArray) > 0
        for i = 0 to array.size(nwogArray) - 1
            NWOGBox nwog = array.get(nwogArray, i)
            bool isCurrent = i == array.size(nwogArray) - 1
            bool allowedByTf = not isOneMinute or isCurrent
            if nwog.isActive and allowedByTf
                bool withinDistance = isWithinPriceDistance(nwog.topPrice, nwog.bottomPrice, close, dailyAtr)
                if withinDistance
                    [fillCol, borderCol, midCol, quadCol] = getGapColors(nwog.gapType)
                    int safeLeftBar = math.max(nwog.startBar, bar_index - 500)
                    
                    if na(nwog.nwogBox)
                        nwog.nwogBox := box.new(safeLeftBar, nwog.topPrice, bar_index + barOffset, nwog.bottomPrice, border_color = borderCol, border_width = boxBorderWidth, bgcolor = fillCol)
                        array.set(nwogArray, i, nwog)

                    if showMidline
                        if na(nwog.midLine)
                            nwog.midLine := line.new(safeLeftBar, nwog.midPrice, bar_index + barOffset, nwog.midPrice, color = midCol, style = getLineStyle(midLineStyle), width = 1)
                            array.set(nwogArray, i, nwog)
                    else
                        if not na(nwog.midLine)
                            line.delete(nwog.midLine)
                            nwog.midLine := na
                            array.set(nwogArray, i, nwog)

                    if showQuadrants
                        if na(nwog.q3Line)
                            nwog.q3Line := line.new(safeLeftBar, nwog.upperQuad, bar_index + barOffset, nwog.upperQuad, color = quadCol, style = getLineStyle(quadLineStyle), width = 1)
                            array.set(nwogArray, i, nwog)
                        if na(nwog.q1Line)
                            nwog.q1Line := line.new(safeLeftBar, nwog.lowerQuad, bar_index + barOffset, nwog.lowerQuad, color = quadCol, style = getLineStyle(quadLineStyle), width = 1)
                            array.set(nwogArray, i, nwog)
                    else
                        if not na(nwog.q3Line)
                            line.delete(nwog.q3Line)
                            nwog.q3Line := na
                            array.set(nwogArray, i, nwog)
                        if not na(nwog.q1Line)
                            line.delete(nwog.q1Line)
                            nwog.q1Line := na
                            array.set(nwogArray, i, nwog)
                    
                    int rightEdge = bar_index + barOffset
                    if extensionMode == "Extend to Week Close" and nwog.weekEnded
                        rightEdge := nwog.weekEndBar
                    
                    if extensionMode == "Extend Live"
                        if not na(nwog.nwogBox)
                            box.set_right(nwog.nwogBox, bar_index + barOffset)
                        if not na(nwog.midLine)
                            line.set_x2(nwog.midLine, bar_index + barOffset)
                        if not na(nwog.q3Line)
                            line.set_x2(nwog.q3Line, bar_index + barOffset)
                        if not na(nwog.q1Line)
                            line.set_x2(nwog.q1Line, bar_index + barOffset)
                    else
                        int targetX = nwog.weekEnded ? nwog.weekEndBar : bar_index + barOffset
                        if not na(nwog.nwogBox)
                            box.set_right(nwog.nwogBox, targetX)
                        if not na(nwog.midLine)
                            line.set_x2(nwog.midLine, targetX)
                        if not na(nwog.q3Line)
                            line.set_x2(nwog.q3Line, targetX)
                        if not na(nwog.q1Line)
                            line.set_x2(nwog.q1Line, targetX)

                    bool shouldShowLabel = showNwogLabels and (extensionMode == "Extend Live" or not nwog.weekEnded) and (not hideHistoryLabels or isCurrent)
                    if shouldShowLabel
                        int daysAgo = calcTradingDaysAgo(nwog.creationTime)
                        string labelText = buildNwogLabelText(nwog.gapType, daysAgo)
                        if na(nwog.infoLabel)
                            nwog.infoLabel := label.new(rightEdge, nwog.midPrice, labelText, xloc.bar_index, yloc.price, color.new(color.white, 100), label.style_label_left, nwogTextColor, getLabelSize(), text.align_left)
                            array.set(nwogArray, i, nwog)
                        else
                            label.set_x(nwog.infoLabel, rightEdge)
                            label.set_text(nwog.infoLabel, labelText)
                            label.set_textcolor(nwog.infoLabel, nwogTextColor)
                    else
                        if not na(nwog.infoLabel)
                            label.delete(nwog.infoLabel)
                            nwog.infoLabel := na
                            array.set(nwogArray, i, nwog)
                else
                    if shouldRunCleanup
                        if not na(nwog.nwogBox)
                            box.delete(nwog.nwogBox)
                            nwog.nwogBox := na
                            array.set(nwogArray, i, nwog)
                        if not na(nwog.midLine)
                            line.delete(nwog.midLine)
                            nwog.midLine := na
                            array.set(nwogArray, i, nwog)
                        if not na(nwog.q3Line)
                            line.delete(nwog.q3Line)
                            nwog.q3Line := na
                            array.set(nwogArray, i, nwog)
                        if not na(nwog.q1Line)
                            line.delete(nwog.q1Line)
                            nwog.q1Line := na
                            array.set(nwogArray, i, nwog)
                        if not na(nwog.infoLabel)
                            label.delete(nwog.infoLabel)
                            nwog.infoLabel := na
                            array.set(nwogArray, i, nwog)
            else
                if not na(nwog.nwogBox)
                    box.delete(nwog.nwogBox)
                    nwog.nwogBox := na
                    array.set(nwogArray, i, nwog)
                if not na(nwog.midLine)
                    line.delete(nwog.midLine)
