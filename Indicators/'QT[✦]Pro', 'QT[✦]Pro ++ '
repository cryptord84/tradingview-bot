                        if not na(ndog.midLine)
                            line.set_x2(ndog.midLine, bar_index + barOffset)
                        if not na(ndog.q3Line)
                            line.set_x2(ndog.q3Line, bar_index + barOffset)
                        if not na(ndog.q1Line)
                            line.set_x2(ndog.q1Line, bar_index + barOffset)
                    else
                        int targetX = ndog.dayEnded ? ndog.dayEndBar : bar_index + barOffset
                        if not na(ndog.ndogBox)
                            box.set_right(ndog.ndogBox, targetX)
                        if not na(ndog.midLine)
                            line.set_x2(ndog.midLine, targetX)
                        if not na(ndog.q3Line)
                            line.set_x2(ndog.q3Line, targetX)
                        if not na(ndog.q1Line)
                            line.set_x2(ndog.q1Line, targetX)

                    bool shouldShowLabel = showNdogLabels and (ndogExtensionMode == "Extend Live" or not ndog.dayEnded) and (not hideHistoryLabels or isCurrent)
                    if shouldShowLabel
                        int daysAgo = calcTradingDaysAgo(ndog.creationTime)
                        string labelText = buildNdogLabelText(ndog.isBullish, daysAgo)
                        if na(ndog.infoLabel)
                            ndog.infoLabel := label.new(rightEdge, ndog.midPrice, labelText, xloc.bar_index, yloc.price, color.new(color.white, 100), label.style_label_left, nwogTextColor, getLabelSize(), text.align_left)
                            array.set(ndogArray, i, ndog)
                        else
                            label.set_x(ndog.infoLabel, rightEdge)
                            label.set_text(ndog.infoLabel, labelText)
                            label.set_textcolor(ndog.infoLabel, nwogTextColor)
                    else
                        if not na(ndog.infoLabel)
                            label.delete(ndog.infoLabel)
                            ndog.infoLabel := na
                            array.set(ndogArray, i, ndog)
                else
                    if shouldRunCleanup
                        if not na(ndog.ndogBox)
                            box.delete(ndog.ndogBox)
                            ndog.ndogBox := na
                            array.set(ndogArray, i, ndog)
                        if not na(ndog.midLine)
                            line.delete(ndog.midLine)
                            ndog.midLine := na
                            array.set(ndogArray, i, ndog)
                        if not na(ndog.q3Line)
                            line.delete(ndog.q3Line)
                            ndog.q3Line := na
                            array.set(ndogArray, i, ndog)
                        if not na(ndog.q1Line)
                            line.delete(ndog.q1Line)
                            ndog.q1Line := na
                            array.set(ndogArray, i, ndog)
                        if not na(ndog.infoLabel)
                            label.delete(ndog.infoLabel)
                            ndog.infoLabel := na
                            array.set(ndogArray, i, ndog)
            else
                if not na(ndog.ndogBox)
                    box.delete(ndog.ndogBox)
                    ndog.ndogBox := na
                    array.set(ndogArray, i, ndog)
                if not na(ndog.midLine)
                    line.delete(ndog.midLine)
                    ndog.midLine := na
                    array.set(ndogArray, i, ndog)
                if not na(ndog.q3Line)
                    line.delete(ndog.q3Line)
                    ndog.q3Line := na
                    array.set(ndogArray, i, ndog)
                if not na(ndog.q1Line)
                    line.delete(ndog.q1Line)
                    ndog.q1Line := na
                    array.set(ndogArray, i, ndog)
                if not na(ndog.infoLabel)
                    label.delete(ndog.infoLabel)
                    ndog.infoLabel := na
                    array.set(ndogArray, i, ndog)

markDayEndForNdogs() =>
    if array.size(ndogArray) > 0
        for i = 0 to array.size(ndogArray) - 1
            NDOGBox ndog = array.get(ndogArray, i)
            if ndog.isActive and not ndog.dayEnded
                if isNewTradingDay
                    ndog.dayEnded := true
                    ndog.dayEndBar := bar_index - 1
                    array.set(ndogArray, i, ndog)

markWeekEndForNwogs() =>
    if array.size(nwogArray) > 0
        for i = 0 to array.size(nwogArray) - 1
            NWOGBox nwog = array.get(nwogArray, i)
            if nwog.isActive and not nwog.weekEnded
                if isWeekCloseRisingEdge
                    nwog.weekEnded := true
                    nwog.weekEndBar := bar_index
                    array.set(nwogArray, i, nwog)

handleWeekClose() =>
    true

if isTfAllowed
    handleWeekClose()
    markWeekEndForNwogs()
    markDayEndForNdogs()
    updateNwogExtensions()
    updateNdogExtensions()

