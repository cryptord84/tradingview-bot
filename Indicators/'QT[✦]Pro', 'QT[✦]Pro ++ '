classifyGap(float friClose, float friOpen, float monOpen) =>
    bool gapUp      = monOpen > friClose
    bool gapDown    = monOpen < friClose
    bool friBullish = friClose > friOpen
    bool friBearish = friClose < friOpen
    int gapType = 0
    if gapUp
        gapType := friBullish ? GAP_VOID_BULL : GAP_OVERLAP_BULL
    else if gapDown
        gapType := friBearish ? GAP_VOID_BEAR : GAP_OVERLAP_BEAR
    gapType

passesAtrFilter(float gapSize, float atr, float multiplier) =>
    if na(atr) or atr == 0
        true
    else if multiplier == 0
        true
    else
        gapSize >= (atr * multiplier)

isWithinPriceDistance(float topPrice, float bottomPrice, float currentPrice, float atr) =>
    if not onlyShowNearPrice
        true
    else if na(atr) or atr == 0
        true
    else
        float distanceToTop    = math.abs(currentPrice - topPrice)
        float distanceToBottom = math.abs(currentPrice - bottomPrice)
        float closestDistance  = math.min(distanceToTop, distanceToBottom)
        float maxDistance      = atr * maxDistanceAtr
        closestDistance <= maxDistance

shouldDisplayGapType(int gapType) =>
    if gapType == GAP_VOID_BULL or gapType == GAP_VOID_BEAR
        showVoidGaps
    else if gapType == GAP_OVERLAP_BULL or gapType == GAP_OVERLAP_BEAR
        showOverlapGaps
    else
        false

var array<NWOGBox> nwogArray = array.new<NWOGBox>()

createNwog(float friClose, float friOpen, float monOpen, float atrVal, int fridayBarIdx) =>
    float topVal    = math.max(friClose, monOpen)
    float bottomVal = math.min(friClose, monOpen)
    float midVal    = (topVal + bottomVal) / 2
    float gapSize   = math.abs(monOpen - friClose)
    float q3Val     = bottomVal + (gapSize * 0.75)
    float q1Val     = bottomVal + (gapSize * 0.25)
    
    int gapType = classifyGap(friClose, friOpen, monOpen)
    bool passesFilter = showNwogs and passesAtrFilter(gapSize, atrVal, atrMultiplier) and shouldDisplayGapType(gapType) and gapType != 0
    int leftBar = na(fridayBarIdx) ? bar_index : fridayBarIdx
    if passesFilter
        NWOGBox newNwog = NWOGBox.new(gapType, friClose, friOpen, monOpen, topVal, bottomVal, midVal, q3Val, q1Val, gapSize, leftBar, time, na, false, na, na, na, na, na, true)
        array.push(nwogArray, newNwog)
        while array.size(nwogArray) > maxNwogCount
            NWOGBox oldest = array.shift(nwogArray)
            if not na(oldest.nwogBox)
                box.delete(oldest.nwogBox)
            if not na(oldest.midLine)
                line.delete(oldest.midLine)
            if not na(oldest.q3Line)
                line.delete(oldest.q3Line)
            if not na(oldest.q1Line)
                line.delete(oldest.q1Line)
            if not na(oldest.infoLabel)
                label.delete(oldest.infoLabel)

