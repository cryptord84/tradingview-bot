// --- DISTANCE FILTER LOGIC ---
daily_atr = request.security(syminfo.tickerid, "D", ta.atr(filter_atr_len), lookahead=barmerge.lookahead_on)

f_is_within_distance(target_price) =>
    if not filter_enabled
        true
    else if na(daily_atr) or daily_atr == 0
        true
    else
        float mult = filter_preset == "Really Close" ? 0.5 : filter_preset == "Balanced" ? 1.0 : 3.0
        float dist = math.abs(close - target_price)
        dist <= (daily_atr * mult)


f_find_exact_in_window(target_price, p_start, p_end, is_high) =>
    int t_exact = p_start 
    if not na(target_price) and not na(p_start) and not na(p_end)
        int max_bars = 4000 
        for i = 0 to max_bars
            if time[i] < p_start
                break
            if time[i] >= p_start and time[i] < p_end
                bool match = false
                if is_high
                    if math.abs(high[i] - target_price) < (syminfo.mintick * 1.5)
                        match := true
                else
                    if math.abs(low[i] - target_price) < (syminfo.mintick * 1.5)
                        match := true
                if match
                    t_exact := time[i]
                    break 
    t_exact

