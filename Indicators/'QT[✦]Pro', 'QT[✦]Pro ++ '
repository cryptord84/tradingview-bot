method applyUniversalPSP(HTFDivergenceSettings this, string preset, string mode, bool precise, bool faster, bool invert3, color bullBody, color bearBody, string asset1, string asset2, string asset3) =>
    this.preset := preset
    this.mode := mode
    this.precise_mode := precise
    this.faster_detection := faster
    this.invert_asset3 := invert3
    this.bull_div_body := bullBody
    this.bear_div_body := bearBody
    this.manual_asset1 := asset1
    this.manual_asset2 := asset2
    this.manual_asset3 := asset3
    this

