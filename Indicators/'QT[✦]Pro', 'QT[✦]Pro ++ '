bool isValidTimeframe930 = timeframe.isintraday and timeframe.multiplier <= 15
var int target_close_h = 16
var int target_close_m = 14
if isStock
    target_close_h := 15
    target_close_m := 59
else
    target_close_h := 16
    target_close_m := 14

[m1_time, m1_open, m1_close] = request.security_lower_tf(syminfo.tickerid, '1', [time, open, close], ignore_invalid_symbol = true)

var float g930_prevClosePrice = na
var box[] g930_boxArray = array.new_box()
var line[] g930_lineArray = array.new_line()

if array.size(m1_time) > 0
    for i = 0 to array.size(m1_time) - 1
        t  = array.get(m1_time, i)
        op = array.get(m1_open, i)
        cl = array.get(m1_close, i)
        int ny_y  = year(t, "America/New_York")
        int ny_mo = month(t, "America/New_York")
        int ny_d  = dayofmonth(t, "America/New_York")
        int t_target_close = timestamp("America/New_York", ny_y, ny_mo, ny_d, target_close_h, target_close_m, 00)
        
        if t == t_target_close
            g930_prevClosePrice := cl
        
        int t_930 = timestamp("America/New_York", ny_y, ny_mo, ny_d, 9, 30, 00)
        if t == t_930
            if g930_historyCount > 0 and not na(g930_prevClosePrice) and isValidTimeframe930
                float gapHigh = math.max(g930_prevClosePrice, op)
                float gapLow  = math.min(g930_prevClosePrice, op)
                float diff    = gapHigh - gapLow
                float lvl50   = gapLow + (diff * 0.50)
                float lvl25   = gapLow + (diff * 0.25)
                float lvl75   = gapLow + (diff * 0.75)
                int t_end = timestamp("America/New_York", ny_y, ny_mo, ny_d, g930_projEndH, g930_projEndM, 0)
                if t_end <= t
                    t_end := t + 60000 
                if g930_showBox
                    newBox = box.new(left = t, top = gapHigh, right = t_end, bottom = gapLow, xloc = xloc.bar_time, bgcolor = g930_boxColor, border_color = color.new(color.white, 90))
                    array.push(g930_boxArray, newBox)
                if g930_showMid
                    ln50 = line.new(x1 = t, y1 = lvl50, x2 = t_end, y2 = lvl50, xloc = xloc.bar_time, color = g930_midColor, style = getLineStyle(g930_midStyleStr))
                    array.push(g930_lineArray, ln50)
                if g930_showQuad
                    ln25 = line.new(x1 = t, y1 = lvl25, x2 = t_end, y2 = lvl25, xloc = xloc.bar_time, color = g930_quadColor, style = getLineStyle(g930_quadStyleStr))
                    array.push(g930_lineArray, ln25)
                    ln75 = line.new(x1 = t, y1 = lvl75, x2 = t_end, y2 = lvl75, xloc = xloc.bar_time, color = g930_quadColor, style = getLineStyle(g930_quadStyleStr))
                    array.push(g930_lineArray, ln75)
                if array.size(g930_boxArray) > g930_historyCount
                    box.delete(array.shift(g930_boxArray))
                while array.size(g930_lineArray) > (g930_historyCount * 3) 
                    line.delete(array.shift(g930_lineArray))
