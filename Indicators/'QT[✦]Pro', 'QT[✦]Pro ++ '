        int groupIndex = -1
        if g1_show and (matchAsset(g1_a1) or matchAsset(g1_a2) or matchAsset(g1_a3))
            groupIndex := 0
        else if g2_show and (matchAsset(g2_a1) or matchAsset(g2_a2) or matchAsset(g2_a3))
            groupIndex := 1
        else if g3_show and (matchAsset(g3_a1) or matchAsset(g3_a2) or matchAsset(g3_a3))
            groupIndex := 2
        else if g4_show and (matchAsset(g4_a1) or matchAsset(g4_a2) or matchAsset(g4_a3))
            groupIndex := 3
        
        if groupIndex != -1
            trioResolved := true
            string[] poolAssets = switch groupIndex
                0 => array.from(g1_a1, g1_a2, g1_a3)
                1 => array.from(g2_a1, g2_a2, g2_a3)
                2 => array.from(g3_a1, g3_a2, g3_a3)
