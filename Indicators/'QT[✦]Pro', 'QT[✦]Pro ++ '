f_draw_single_level(t_start, t_end, price, txt, col, sty, show_lbl, size_val, font_val) =>
    if f_is_within_distance(price)
        l = line.new(t_start, price, t_end, price, xloc=xloc.bar_time, color=col, style=sty)
        array.push(draw_lines, l)
        if show_lbl
            lb = label.new(t_end, price, txt, xloc=xloc.bar_time, color=color.new(color.white, 100), style=label.style_label_left, textcolor=col, size=size_val, text_font_family=font_val)
            array.push(draw_labels, lb)

f_draw_levels(arr, show, mode, show_lbl, col, sty_global, txt_base, txt_size_val, font_val) =>
    if show and array.size(arr) > 0
        sty = f_get_style(sty_global)
        int forward_offset = timeframe.in_seconds(timeframe.period) * 1000 * 10
        int t_future = time + forward_offset
        
        for i = 0 to array.size(arr) - 1
            Level lvl = array.get(arr, i)
            
            // --- DRAW HIGHS & LOWS ---
            int t_end_hl = lvl.broken ? lvl.stop_time : t_future
            string lbl_txt = txt_base + (lvl.is_high ? ".H" : ".L")
            string lbl_style_hl = lvl.is_high ? (lvl.broken ? label.style_label_down : label.style_label_left) : (lvl.broken ? label.style_label_up : label.style_label_left)
            
            if f_is_within_distance(lvl.price) and lvl.start_time < t_end_hl
                l = line.new(lvl.start_time, lvl.price, t_end_hl, lvl.price, xloc=xloc.bar_time, color=col, style=sty)
                array.push(draw_lines, l)
                
                if show_lbl
                    lb = label.new(t_end_hl, lvl.price, lbl_txt, xloc=xloc.bar_time, color=color.new(color.white, 100), style=lbl_style_hl, textcolor=col, size=txt_size_val, text_font_family=font_val)
                    array.push(draw_labels, lb)

            // --- DRAW EQ / QUADRANTS ---
            if mode != "None" and i == 0 and array.size(arr) >= 2
                Level partner = array.get(arr, 1) 
                
                float h_price = math.max(lvl.price, partner.price)
                float l_price = math.min(lvl.price, partner.price)
                int eq_start  = math.min(lvl.start_time, partner.start_time)
                float diff    = h_price - l_price
                
                f_draw_single_level(eq_start, t_future, l_price + (diff * 0.5), txt_base + ".EQ", col, sty, show_lbl, txt_size_val, font_val)
                
                if mode == "Quadrants"
                    f_draw_single_level(eq_start, t_future, l_price + (diff * 0.75), txt_base + ".75", col, sty, show_lbl, txt_size_val, font_val)
                    f_draw_single_level(eq_start, t_future, l_price + (diff * 0.25), txt_base + ".25", col, sty, show_lbl, txt_size_val, font_val)

