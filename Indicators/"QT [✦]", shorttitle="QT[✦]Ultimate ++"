                if low < box.get_bottom(qt_box_main) 
                    box.set_bottom(qt_box_main, low)
                if qt_show_lbl_main and not na(qt_lbl_main)
                    label.set_y(qt_lbl_main, box.get_top(qt_box_main))
                    
        // 90 MINUTE CYCLES
        if qt_show_90
            int qt_idx_90 = math.floor(qt_time_elapsed / MS_90)
