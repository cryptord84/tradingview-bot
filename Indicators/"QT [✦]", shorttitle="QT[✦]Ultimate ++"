f_get_sb_color_norm(_arr, _c_bull, _c_bear, _c_sand, _c_neut) =>
    // Step 1: Extract "Facts" (Cleared Levels)
    // Index 5 = Bullish Run (Highs Cleared)
    // Index 4 = Bearish Run (Lows Cleared)
    bool _run_bull = array.size(_arr) > 9 ? array.get(_arr, 5) : false
    bool _run_bear = array.size(_arr) > 9 ? array.get(_arr, 4) : false

    // Step 2: Extract "Theories" (Active Divergences)
    // Indices 2,3,7 = Bullish Divergence
    bool _div_bull = array.size(_arr) > 9 ? (array.get(_arr, 3) or array.get(_arr, 2) or array.get(_arr, 7)) : false
    // Indices 0,1,6 = Bearish Divergence
    bool _div_bear = array.size(_arr) > 9 ? (array.get(_arr, 1) or array.get(_arr, 0) or array.get(_arr, 6)) : false

    color _c_out = _c_neut 

    // Step 3: Hierarchy of Conflicts (The "Sandwich" Check)
    
    // CASE A: Total Chaos (Both sides Cleared) -> SANDWICH
    bool _conflict_runs = _run_bull and _run_bear
    
    // CASE B: Bearish Clear vs Bullish Divergence -> SANDWICH
    // (We ran the lows, but now we see bullish SMT)
    bool _conflict_bear_run_bull_div = _run_bear and _div_bull
    
    // CASE C: Bullish Clear vs Bearish Divergence -> SANDWICH
    // (We ran the highs, but now we see bearish SMT)
    bool _conflict_bull_run_bear_div = _run_bull and _div_bear
    
    // CASE D: Standard Theory Conflict -> SANDWICH
    bool _conflict_divs = _div_bull and _div_bear

    // --- APPLY COLORS ---
    
    if _conflict_runs or _conflict_bear_run_bull_div or _conflict_bull_run_bear_div or _conflict_divs
        _c_out := _c_sand  // Any conflict = Sandwich
        
    else if _run_bull      // Clean Bullish Run (No bear divergence)
        _c_out := _c_bull
        
    else if _run_bear      // Clean Bearish Run (No bull divergence)
        _c_out := _c_bear
        
    else if _div_bull      // Clean Bullish Divergence
        _c_out := _c_bull
        
    else if _div_bear      // Clean Bearish Divergence
        _c_out := _c_bear
    
    _c_out

