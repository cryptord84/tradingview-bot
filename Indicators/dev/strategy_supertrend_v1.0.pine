//@version=6
strategy("Supertrend v1.0 — Backtest",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.1,
     slippage=3)

// ── Inputs ──────────────────────────────────────────────────────────────────
atrLen    = input.int(10,    "ATR Length",         minval=1)
factor    = input.float(3.0, "Supertrend Factor",  minval=0.1, step=0.1)
useVol    = input.bool(true, "Volume Filter")
volMult   = input.float(1.2, "Min Volume (× MA)",  minval=1.0, step=0.1)
volLen    = input.int(20,    "Volume MA Length",   minval=5)
useShort  = input.bool(true, "Enable Short Side")

// ── Supertrend ───────────────────────────────────────────────────────────────
[stLine, stDir] = ta.supertrend(factor, atrLen)

// direction: -1 = bullish (price above line), 1 = bearish (price below line)
bullFlip  = stDir == -1 and stDir[1] == 1   // just turned bullish
bearFlip  = stDir ==  1 and stDir[1] == -1  // just turned bearish

// ── Volume Filter ────────────────────────────────────────────────────────────
volMA  = ta.sma(volume, volLen)
volOk  = not useVol or volume > volMA * volMult

// ── Entries ──────────────────────────────────────────────────────────────────
if bullFlip and volOk
    strategy.entry("Long", strategy.long)

if bearFlip and useShort and volOk
    strategy.entry("Short", strategy.short)

// ── Exits ─────────────────────────────────────────────────────────────────────
if bearFlip
    strategy.close("Long")
if bullFlip
    strategy.close("Short")

// ── Plot ─────────────────────────────────────────────────────────────────────
stColor = stDir == -1 ? color.new(color.green, 0) : color.new(color.red, 0)
plot(stLine, "Supertrend", color=stColor, linewidth=2)
plotshape(bullFlip and volOk, "Long",  shape.triangleup,   location.belowbar, color.green, size=size.small)
plotshape(bearFlip and volOk, "Short", shape.triangledown, location.abovebar, color.red,   size=size.small)
